  "types": "src/index.ts",
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "expo",
    "expo-modules",
    "ios",
    "apple-llm",
    "foundation-models",
    "apple-intelligence",
    "llm",
    "on-device",
    "language-model-session"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nabettu/expo-apple-llm.git"
  },
  "bugs": {
    "url": "https://github.com/nabettu/expo-apple-llm/issues"
  },
  "homepage": "https://github.com/nabettu/expo-apple-llm#readme",
  "author": "nabettu",
  "license": "MIT",
  "files": [
    "src",
    "ios",
    "index.ts",
    "expo-module.config.json",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "expo": ">=54.0.0",
    "react-native": "*"
  },
  "devDependencies": {
    "expo-modules-core": "~2.3.0",
    "typescript": "~5.8.0"
  }
}
